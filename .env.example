# CMON Configuration File
# This file is embedded in the binary during build

# DGVCL Portal Credentials (REQUIRED)
DGVCL_USERNAME=
DGVCL_PASSWORD=

# Telegram Configuration (REQUIRED for notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# WhatsApp Configuration (optional — leave WHATSAPP_RECIPIENT_JID blank to disable)
# Format for a personal number: 919876543210@s.whatsapp.net  (country code + number, no '+')
# Format for a group:           XXXXXXXXXXXXXXXXXX@g.us
WHATSAPP_RECIPIENT_JID=
WHATSAPP_DB_PATH=whatsapp.db
# Set to true to allow users to resolve complaints by replying "resolve <remark>" on WhatsApp
WHATSAPP_RESOLVE_ENABLED=true

# Portal URLs (usually don't need to change)
LOGIN_URL=https://complaint.dgvcl.com/
COMPLAINT_URL=https://complaint.dgvcl.com/dashboard_complaint_list?from_date=&to_date=&honame=1&coname=21&doname=24&sdoname=87&cStatus=2&commobile=

# Retry Configuration
MAX_LOGIN_RETRIES=3
MAX_FETCH_RETRIES=2
LOGIN_RETRY_DELAY=5s

# Pagination
MAX_PAGES=5

# Timing Configuration
FETCH_INTERVAL=15m
FETCH_TIMEOUT=10m
NAVIGATION_TIMEOUT=60s
WAIT_TIMEOUT=45s

# Performance Tuning
WORKER_POOL_SIZE=5
CACHE_ENABLED=true
BATCH_SIZE=50
HTTP_MAX_CONNS=100
HTTP_TIMEOUT=30s

# Health Check
HEALTH_CHECK_PORT=8080

# Debug Mode (set to true for testing)
DEBUG_MODE=true

# Gemini AI Translation (optional - for Gujarati transliteration)
GEMINI_API_KEY=

